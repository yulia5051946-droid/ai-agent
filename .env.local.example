# Google OAuth（至 console.cloud.google.com 建立）
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-random-secret-here

# Anthropic Claude API
ANTHROPIC_API_KEY=

# 每日日報 SMTP 設定（用於 Cron 寄信）
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=liny@garena.com
SMTP_PASS=your-app-password

# 日報收件人（逗號分隔）
DAILY_REPORT_TO=liny@garena.com,chenla@garena.com

# 資料庫路徑
DB_PATH=./data/contracts.db

# 環境
NODE_ENV=production
